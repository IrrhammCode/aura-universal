generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id           String           @id @default(cuid())
  name         String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  agents       Agent[]
  chatMessages ChatMessage[]
  documents    Document[]
  logs         InteractionLog[]
  leads        Lead[]
  settings     Settings?
  users        User[]
  videos       VideoJob[]
  tickets      ServiceTicket[]
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String?
  role           String       @default("MEMBER")
  organizationId String
  createdAt      DateTime     @default(now())
  avatar         String?
  passwordHash   String?
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Settings {
  id                String       @id @default(cuid())
  organizationId    String       @unique
  heygenKey         String?
  elevenLabsKey     String?
  falKey            String?
  openAiKey         String?
  companyLogo       String?
  primaryColor      String       @default("#06b6d4")
  calendlyUrl       String?
  twoFactorAuth     Boolean      @default(true)
  restrictedRegions String       @default("None")
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id])
}

model Agent {
  id              String       @id @default(cuid())
  organizationId  String
  name            String
  avatarId        String?
  voiceId         String?
  instructions    String?
  templateType    String?
  themeColor      String       @default("#06b6d4")
  tone            Int          @default(50)
  empathy         Int          @default(50)
  depth           Int          @default(50)
  createdAt       DateTime     @default(now())
  logoUrl         String?
  welcomeVideoUrl String?
  organization    Organization @relation(fields: [organizationId], references: [id])
}

model Lead {
  id             String       @id @default(cuid())
  organizationId String
  email          String?
  name           String?
  phone          String?
  status         String       @default("NEW")
  sourceAgentId  String?
  sessionId      String?
  lastMessage    String?
  isPaused       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Document {
  id             String          @id @default(cuid())
  organizationId String
  title          String
  url            String?
  size           String?
  vectors        Int             @default(0)
  createdAt      DateTime        @default(now())
  content        String?
  organization   Organization    @relation(fields: [organizationId], references: [id])
  chunks         DocumentChunk[]
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  content    String
  embedding  String
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model VideoJob {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  duration       String
  htmlContent    String?
  funnelUrl      String?
  heygenId       String?
  videoUrl       String?
  status         String       @default("PROCESSING")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model InteractionLog {
  id             String       @id @default(cuid())
  organizationId String
  input          String
  response       String
  hasVision      Boolean      @default(false)
  time           String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model ChatMessage {
  id             String       @id @default(cuid())
  organizationId String
  agentId        String
  role           String
  content        String
  hasImage       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  sessionId      String?
  organization   Organization @relation(fields: [organizationId], references: [id])
}
model ServiceTicket {
  id             String       @id @default(cuid())
  organizationId String
  ticketId       String       @unique
  customerEmail  String?
  customerName   String?
  issueTitle     String
  issueSummary   String?
  issueImage     String?
  status         String       @default("PENDING")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
}
